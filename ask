#!/usr/bin/env bash
set -euo pipefail

CONFIG="$HOME/.config/ask/config"

load_cfg() { [ -f "$CONFIG" ] && source "$CONFIG" || true; }
save_cfg()  { echo "$1=\"$2\"" >>"$CONFIG"; }

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    printf '%s' "$str"
}

ask() {
    local prompt body
    prompt=$(json_escape "$*")
    body="{\"model\":\"${MODEL:-gpt-4o-mini}\",\"messages\":[{\"role\":\"user\",\"content\":\"$prompt\"}],\"stream\":true}"

    curl -sS --no-buffer "${ENDPOINT%/}/chat/completions" \
        -H "Authorization: Bearer $API_KEY" \
        -H "Content-Type: application/json" \
        -d "$body" | while IFS= read -r line; do
        line="${line#data: }"
        [ "$line" = "[DONE]" ] && break
        content=$(printf '%s' "$line" | sed -n 's/.*"content":"\([^"]*\)".*/\1/p')
        [ -n "$content" ] && printf '%b' "$content"
    done
    echo
}

help() {
    cat <<'EOF'
ask - CLI LLM assistant

Usage:
  ask <question>                  ask the LLM
  ask --set-key <api-key>         save API key
  ask --set-model <model>         set model
  ask --set-endpoint <endpoint>   set API endpoint
  ask --help                      show this help

API key can also set via env: ASK_API_KEY
Config file: ~/.config/ask/config
EOF
}

# ── main ──
load_cfg
[ $# -lt 1 ] && { help; exit 1; }

case "$1" in
    --help|-h) help; exit 0 ;;
    --set-key)
        [ $# -lt 2 ] && { echo "Error: missing key" >&2; exit 1; }
        mkdir -p "$(dirname "$CONFIG")"
        echo "API_KEY=\"$2\"" >"$CONFIG"
        echo "API key saved."
        ;;
    --set-model)
        [ $# -lt 2 ] && { echo "Error: missing model" >&2; exit 1; }
        save_cfg MODEL "$2"
        echo "Model set to: $2"
        ;;
    --set-endpoint)
        [ $# -lt 2 ] && { echo "Error: missing endpoint" >&2; exit 1; }
        save_cfg ENDPOINT "$2"
        echo "Endpoint set to: $2"
        ;;
    *)
        API_KEY="${API_KEY:-${ASK_API_KEY:-}}"
        [ -z "$API_KEY" ] && { echo "Error: no API key. Set with 'ask --set-key <key>'." >&2; exit 1; }
        ask "$@"
        ;;
esac

#!/usr/bin/env bash
set -euo pipefail

CONFIG="$HOME/.config/ask/config"

load_cfg() { [ -f "$CONFIG" ] && source "$CONFIG" || true; }
save_cfg()  { echo "$1=\"$2\"" >>"$CONFIG"; }

json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    printf '%s' "$str"
}

ask() {
    local prompt body sys_msg
    prompt=$(json_escape "$*")
    case "${VERBOSE:-medium}" in
        low)    sys_msg=$(json_escape "回答尽量简短，1-3句话，不要多余解释。不要用Markdown格式和代码块。");;
        medium) sys_msg=$(json_escape "回答可以包含要点，但保持简洁。不要用Markdown格式和代码块。");;
        high)   sys_msg=$(json_escape "不要使用Markdown格式和代码块。");;
    esac
    body="{\"model\":\"${MODEL:-gpt-4o-mini}\",\"messages\":[{\"role\":\"system\",\"content\":\"$sys_msg\"},{\"role\":\"user\",\"content\":\"$prompt\"}],\"stream\":true}"

    curl -sS --no-buffer "${ENDPOINT%/}/chat/completions" \
        -H "Authorization: Bearer $API_KEY" \
        -H "Content-Type: application/json" \
        -d "$body" | while IFS= read -r line; do
        line="${line#data: }"
        [ "$line" = "[DONE]" ] && break
        content=$(printf '%s' "$line" | sed -n 's/.*"content":"\([^"]*\)".*/\1/p')
        [ -n "$content" ] && printf '%b' "$content"
    done
    echo
}

help() {
    cat <<'EOF'
ask - CLI LLM assistant

Usage:
  ask <question>

Config:
  ask -k <key>          set API key          (--set-key)
  ask -m <model>        set model            (--set-model)
  ask -e <endpoint>     set API endpoint     (--set-endpoint)
  ask -v low|medium|high set verbosity (default: medium) (--set-verbose)
  ask -h                show this help       (--help)

API key can also be set via env: ASK_API_KEY
Config file: ~/.config/ask/config
EOF
}

# ── main ──
load_cfg
[ $# -lt 1 ] && { help; exit 1; }

case "$1" in
    -h|--help) help; exit 0 ;;
    -k|--set-key)
        [ $# -lt 2 ] && { echo "Error: missing key" >&2; exit 1; }
        mkdir -p "$(dirname "$CONFIG")"
        echo "API_KEY=\"$2\"" >"$CONFIG"
        echo "API key saved."
        ;;
    -m|--set-model)
        [ $# -lt 2 ] && { echo "Error: missing model" >&2; exit 1; }
        save_cfg MODEL "$2"
        echo "Model set to: $2"
        ;;
    -e|--set-endpoint)
        [ $# -lt 2 ] && { echo "Error: missing endpoint" >&2; exit 1; }
        save_cfg ENDPOINT "$2"
        echo "Endpoint set to: $2"
        ;;
    -v|--set-verbose)
        [ $# -lt 2 ] && { echo "Error: missing level (low|medium|high)" >&2; exit 1; }
        case "$2" in low|medium|high) ;; *) echo "Error: must be low, medium, or high" >&2; exit 1 ;; esac
        save_cfg VERBOSE "$2"
        echo "Verbosity set to: $2"
        ;;
    *)
        API_KEY="${API_KEY:-${ASK_API_KEY:-}}"
        [ -z "$API_KEY" ] && { echo "Error: no API key. Set with 'ask -k <key>'." >&2; exit 1; }
        ask "$@"
        ;;
esac
